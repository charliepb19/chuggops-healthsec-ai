# ─── ChuggOps HealthSec AI — Environment Variables ────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked REQUIRED before deploying
# 3. Never commit .env to source control — it contains secrets

# ── Admin account (seeded on first startup) ───────────────────────────────────
# REQUIRED — change before deploying
CHUGGOPS_ADMIN_USER=admin
CHUGGOPS_ADMIN_PASS=change-me-before-deploying

# ── Session signing key ───────────────────────────────────────────────────────
# REQUIRED — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-before-deploying

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (default — no value needed, uses SQLite file):
# DATABASE_URL=sqlite:///./chuggops.db

# Docker / production — DB_PASSWORD is used by docker-compose.yml to build
# the PostgreSQL connection string automatically. REQUIRED when using Docker.
DB_PASSWORD=change-me-strong-random-password

# Direct override (if running PostgreSQL without Docker):
# DATABASE_URL=postgresql://chuggops:yourpassword@localhost:5432/chuggops

# ── OpenAI API key ────────────────────────────────────────────────────────────
# Optional — enables AI-powered alert analysis. Falls back to rule-based if unset.
# OPENAI_API_KEY=sk-...

# ── Email notifications ───────────────────────────────────────────────────────
# Optional — HIGH and CRITICAL alerts send an email when configured.
# Works with any SMTP provider (Gmail app password, Outlook, SendGrid, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=your-app-password
# ALERT_EMAIL_TO=security@hospital.org,oncall@hospital.org

# ── ML model ──────────────────────────────────────────────────────────────────
# Optional — where the trained Isolation Forest is saved.
# In Docker this maps to the ml_models named volume (set automatically).
# ML_MODEL_PATH=models/isolation_forest.pkl

# ── Performance ───────────────────────────────────────────────────────────────
# Optional — uvicorn worker processes. Default 2. Keep at or below CPU count.
# WORKERS=2
